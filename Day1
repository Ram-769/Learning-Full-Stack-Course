<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Day 1 — Node.js Fundamentals | 30-Day Mastery</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Inter:wght@300;400;500;600;700&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">
<style>
:root[data-theme="dark"] {
  --bg: #0d0f14;
  --bg2: #13161e;
  --bg3: #1a1e2a;
  --bg4: #222636;
  --border: #2a2e3f;
  --text: #e2e8f0;
  --text2: #94a3b8;
  --text3: #64748b;
  --green: #22c55e;
  --green-dim: rgba(34,197,94,0.12);
  --green-glow: rgba(34,197,94,0.3);
  --accent: #6366f1;
  --accent2: #818cf8;
  --accent-dim: rgba(99,102,241,0.12);
  --yellow: #f59e0b;
  --yellow-dim: rgba(245,158,11,0.12);
  --red: #ef4444;
  --red-dim: rgba(239,68,68,0.12);
  --cyan: #06b6d4;
  --cyan-dim: rgba(6,182,212,0.12);
  --node-green: #68a063;
}
:root[data-theme="light"] {
  --bg: #f1f5f9;
  --bg2: #ffffff;
  --bg3: #f8fafc;
  --bg4: #e2e8f0;
  --border: #cbd5e1;
  --text: #0f172a;
  --text2: #475569;
  --text3: #94a3b8;
  --green: #16a34a;
  --green-dim: rgba(22,163,74,0.1);
  --green-glow: rgba(22,163,74,0.25);
  --accent: #4f46e5;
  --accent2: #6366f1;
  --accent-dim: rgba(79,70,229,0.1);
  --yellow: #d97706;
  --yellow-dim: rgba(217,119,6,0.1);
  --red: #dc2626;
  --red-dim: rgba(220,38,38,0.1);
  --cyan: #0891b2;
  --cyan-dim: rgba(8,145,178,0.1);
  --node-green: #3d7a38;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Inter', sans-serif;
  background: var(--bg);
  color: var(--text);
  display: flex;
  min-height: 100vh;
  font-size: 15px;
  line-height: 1.7;
}

/* ===== SIDEBAR ===== */
.sidebar {
  width: 280px;
  min-width: 280px;
  background: var(--bg2);
  border-right: 1px solid var(--border);
  height: 100vh;
  position: sticky;
  top: 0;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  z-index: 100;
}
.sidebar::-webkit-scrollbar { width: 4px; }
.sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

.sidebar-header {
  padding: 20px 16px 16px;
  border-bottom: 1px solid var(--border);
}
.logo {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
}
.logo-icon {
  width: 36px; height: 36px;
  background: linear-gradient(135deg, var(--node-green), #4ade80);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'JetBrains Mono', monospace;
  font-weight: 700; font-size: 13px; color: #fff;
}
.logo-text { font-family: 'Sora', sans-serif; font-size: 14px; font-weight: 700; color: var(--text); }
.logo-text span { color: var(--green); }

.search-box {
  display: flex; align-items: center; gap: 8px;
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: 8px; padding: 8px 12px;
}
.search-box input {
  background: none; border: none; outline: none;
  color: var(--text); font-size: 13px; width: 100%; font-family: 'Inter', sans-serif;
}
.search-box input::placeholder { color: var(--text3); }
.search-icon { color: var(--text3); font-size: 14px; }

.progress-card {
  margin: 14px 16px;
  background: var(--green-dim);
  border: 1px solid var(--green-glow);
  border-radius: 10px;
  padding: 12px;
}
.progress-label { font-size: 11px; color: var(--green); text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600; margin-bottom: 8px; }
.progress-bar-wrap { background: var(--bg4); border-radius: 100px; height: 6px; margin-bottom: 6px; }
.progress-bar { height: 6px; border-radius: 100px; background: linear-gradient(90deg, var(--green), #4ade80); width: 3.33%; transition: width 0.4s; }
.progress-text { font-size: 12px; color: var(--text2); display: flex; justify-content: space-between; }

.section-label {
  font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em;
  color: var(--text3); font-weight: 600;
  padding: 14px 16px 6px;
}

.day-list { list-style: none; padding: 0 8px 8px; }
.day-item {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 10px; border-radius: 8px;
  cursor: pointer; transition: background 0.15s;
  font-size: 13px; color: var(--text2);
}
.day-item:hover { background: var(--bg3); }
.day-item.active {
  background: var(--accent-dim);
  color: var(--accent2);
  font-weight: 600;
}
.day-item.done { color: var(--green); }
.day-badge {
  width: 20px; height: 20px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 700; flex-shrink: 0;
  background: var(--bg4);
  color: var(--text3);
}
.day-item.active .day-badge { background: var(--accent); color: #fff; }
.day-item.done .day-badge { background: var(--green-dim); color: var(--green); }
.locked-days { padding: 0 8px 16px; }
.locked-label { font-size: 11px; color: var(--text3); padding: 4px 10px; }

/* ===== TOPBAR ===== */
.main-wrap { flex: 1; display: flex; flex-direction: column; min-width: 0; }

.topbar {
  position: sticky; top: 0; z-index: 90;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 28px; height: 56px;
  gap: 16px;
}
.topbar-left { display: flex; align-items: center; gap: 12px; }
.breadcrumb { font-size: 13px; color: var(--text3); }
.breadcrumb span { color: var(--text2); }
.breadcrumb strong { color: var(--green); }
.topbar-right { display: flex; align-items: center; gap: 10px; }

.btn {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 7px 14px; border-radius: 7px;
  font-size: 13px; font-weight: 500; cursor: pointer;
  border: 1px solid var(--border); background: var(--bg3); color: var(--text2);
  transition: all 0.15s; font-family: 'Inter', sans-serif;
}
.btn:hover { border-color: var(--accent); color: var(--accent2); }
.btn-primary { background: var(--accent); border-color: var(--accent); color: #fff; }
.btn-primary:hover { background: var(--accent2); border-color: var(--accent2); color: #fff; }
.btn-green { background: var(--green-dim); border-color: var(--green); color: var(--green); }

.theme-toggle {
  width: 36px; height: 36px; border-radius: 8px;
  background: var(--bg3); border: 1px solid var(--border);
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  font-size: 16px; transition: all 0.15s;
}
.theme-toggle:hover { border-color: var(--accent); }

/* ===== CONTENT ===== */
.content { flex: 1; padding: 32px 28px 80px; max-width: 900px; }

.day-hero {
  background: linear-gradient(135deg, var(--bg2) 0%, var(--bg3) 100%);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 28px 32px;
  margin-bottom: 32px;
  position: relative; overflow: hidden;
}
.day-hero::before {
  content: '';
  position: absolute; top: -40px; right: -40px;
  width: 160px; height: 160px;
  background: radial-gradient(circle, var(--green-glow), transparent 70%);
  pointer-events: none;
}
.day-tag {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--green-dim); border: 1px solid var(--green);
  color: var(--green); border-radius: 100px;
  padding: 4px 12px; font-size: 11px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 12px;
}
.day-hero h1 { font-family: 'Sora', sans-serif; font-size: 26px; font-weight: 800; margin-bottom: 8px; }
.day-hero h1 span { color: var(--green); }
.day-hero p { color: var(--text2); font-size: 15px; max-width: 580px; margin-bottom: 20px; }
.hero-meta { display: flex; gap: 20px; flex-wrap: wrap; }
.hero-meta-item { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--text3); }
.hero-meta-item strong { color: var(--text2); }

/* Section */
.section {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 14px;
  margin-bottom: 24px;
  overflow: hidden;
}
.section-head {
  display: flex; align-items: center; gap: 12px;
  padding: 18px 24px;
  border-bottom: 1px solid var(--border);
  cursor: pointer; user-select: none;
  transition: background 0.15s;
}
.section-head:hover { background: var(--bg3); }
.section-num {
  width: 32px; height: 32px; border-radius: 8px;
  background: var(--accent-dim); color: var(--accent2);
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 700; font-family: 'JetBrains Mono', monospace;
  flex-shrink: 0;
}
.section-title { font-weight: 600; font-size: 15px; flex: 1; }
.section-chevron { color: var(--text3); transition: transform 0.2s; font-size: 14px; }
.section.open .section-chevron { transform: rotate(180deg); }
.section-body { padding: 24px; display: none; }
.section.open .section-body { display: block; }

h2 { font-family: 'Sora', sans-serif; font-size: 20px; font-weight: 700; margin-bottom: 14px; }
h3 { font-size: 15px; font-weight: 600; margin-bottom: 10px; color: var(--text); }
h4 { font-size: 13px; font-weight: 600; margin-bottom: 8px; color: var(--text2); text-transform: uppercase; letter-spacing: 0.05em; }
p { color: var(--text2); margin-bottom: 12px; }
ul, ol { color: var(--text2); padding-left: 18px; margin-bottom: 12px; }
li { margin-bottom: 6px; }

/* Diagram */
.diagram {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 20px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 13px;
  margin: 16px 0;
  text-align: center;
  color: var(--text2);
  line-height: 2;
}
.diagram .node {
  display: inline-block;
  background: var(--bg4);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 6px 20px;
  margin: 3px;
  color: var(--text);
  font-size: 12px;
}
.diagram .node.green { background: var(--green-dim); border-color: var(--green); color: var(--green); }
.diagram .node.purple { background: var(--accent-dim); border-color: var(--accent); color: var(--accent2); }
.diagram .node.yellow { background: var(--yellow-dim); border-color: var(--yellow); color: var(--yellow); }
.diagram .node.cyan { background: var(--cyan-dim); border-color: var(--cyan); color: var(--cyan); }
.diagram .arrow { color: var(--text3); display: block; margin: 0; }

/* Code block */
.code-block {
  background: #0a0c12;
  border: 1px solid var(--border);
  border-radius: 10px;
  overflow: hidden;
  margin: 14px 0;
}
:root[data-theme="light"] .code-block { background: #1e1e2e; }
.code-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 10px 16px;
  background: rgba(255,255,255,0.03);
  border-bottom: 1px solid var(--border);
}
.code-lang { font-size: 11px; font-family: 'JetBrains Mono', monospace; color: var(--green); font-weight: 600; }
.code-copy { font-size: 11px; color: var(--text3); cursor: pointer; }
.code-copy:hover { color: var(--accent2); }
pre {
  padding: 16px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 13px;
  line-height: 1.7;
  overflow-x: auto;
  color: #e2e8f0;
  margin: 0;
}
.kw { color: #c792ea; }
.fn { color: #82aaff; }
.str { color: #c3e88d; }
.cm { color: #546e7a; font-style: italic; }
.num { color: #f78c6c; }
.op { color: #89ddff; }
.var { color: #eeffff; }

/* Cards */
.card-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 14px; margin: 16px 0; }
.card {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 16px;
}
.card.green-card { border-left: 3px solid var(--green); }
.card.purple-card { border-left: 3px solid var(--accent); }
.card.yellow-card { border-left: 3px solid var(--yellow); }
.card.red-card { border-left: 3px solid var(--red); }
.card.cyan-card { border-left: 3px solid var(--cyan); }
.card-icon { font-size: 22px; margin-bottom: 8px; }
.card-title { font-weight: 600; font-size: 14px; margin-bottom: 4px; }
.card-desc { font-size: 12px; color: var(--text2); line-height: 1.5; }

/* Table */
.table-wrap { overflow-x: auto; margin: 16px 0; }
table { width: 100%; border-collapse: collapse; font-size: 13px; }
th {
  background: var(--bg3); padding: 10px 14px;
  text-align: left; color: var(--text2);
  font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600;
  border-bottom: 1px solid var(--border);
}
td { padding: 10px 14px; border-bottom: 1px solid var(--border); color: var(--text2); }
tr:last-child td { border-bottom: none; }
tr:hover td { background: var(--bg3); }
.tag-yes { color: var(--green); font-weight: 600; }
.tag-no { color: var(--red); font-weight: 600; }

/* Callout */
.callout {
  border-radius: 10px; padding: 14px 16px; margin: 14px 0;
  display: flex; gap: 12px; align-items: flex-start;
}
.callout.info { background: var(--accent-dim); border: 1px solid var(--accent); }
.callout.success { background: var(--green-dim); border: 1px solid var(--green); }
.callout.warning { background: var(--yellow-dim); border: 1px solid var(--yellow); }
.callout.error { background: var(--red-dim); border: 1px solid var(--red); }
.callout-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
.callout-text { font-size: 13px; color: var(--text2); line-height: 1.6; }
.callout-text strong { color: var(--text); }

/* Quiz */
.quiz-q {
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: 10px; padding: 16px; margin-bottom: 14px;
}
.quiz-q-text { font-weight: 600; font-size: 14px; margin-bottom: 12px; }
.quiz-options { display: flex; flex-direction: column; gap: 8px; }
.quiz-option {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 14px; border-radius: 8px;
  border: 1px solid var(--border); background: var(--bg4);
  cursor: pointer; font-size: 13px; color: var(--text2);
  transition: all 0.15s;
}
.quiz-option:hover { border-color: var(--accent); color: var(--accent2); }
.quiz-option.correct { border-color: var(--green); background: var(--green-dim); color: var(--green); }
.quiz-option.wrong { border-color: var(--red); background: var(--red-dim); color: var(--red); }
.quiz-opt-key {
  width: 24px; height: 24px; border-radius: 6px;
  background: var(--bg); border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 700; flex-shrink: 0;
  font-family: 'JetBrains Mono', monospace;
}
.quiz-explain { display: none; margin-top: 10px; padding: 10px 12px; background: var(--green-dim); border-radius: 8px; font-size: 13px; color: var(--green); }

/* Interview Q */
.iq-item {
  border: 1px solid var(--border); border-radius: 10px;
  margin-bottom: 12px; overflow: hidden;
}
.iq-question {
  padding: 14px 16px; display: flex; align-items: flex-start; gap: 10px;
  cursor: pointer; background: var(--bg3); font-size: 14px; font-weight: 500;
  transition: background 0.15s;
}
.iq-question:hover { background: var(--bg4); }
.iq-q-num {
  background: var(--accent-dim); color: var(--accent2);
  border-radius: 6px; padding: 2px 7px; font-size: 11px;
  font-weight: 700; font-family: 'JetBrains Mono', monospace; flex-shrink: 0; margin-top: 2px;
}
.iq-answer { display: none; padding: 14px 16px; border-top: 1px solid var(--border); font-size: 13px; color: var(--text2); }
.iq-answer.show { display: block; }
.iq-answer-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--green); font-weight: 700; margin-bottom: 6px; }

/* Analogy */
.analogy {
  background: var(--yellow-dim); border: 1px solid var(--yellow);
  border-radius: 10px; padding: 16px; margin: 16px 0;
}
.analogy-title { font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--yellow); font-weight: 700; margin-bottom: 8px; }
.analogy-body { font-size: 13px; color: var(--text2); }

/* Mistake / Tip */
.tips-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin: 14px 0; }
.tip-card { background: var(--bg3); border-radius: 10px; padding: 14px; border: 1px solid var(--border); }
.tip-bad { border-top: 3px solid var(--red); }
.tip-good { border-top: 3px solid var(--green); }
.tip-header { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 10px; }
.tip-bad .tip-header { color: var(--red); }
.tip-good .tip-header { color: var(--green); }
.tip-item { font-size: 12px; color: var(--text2); margin-bottom: 6px; padding-left: 14px; position: relative; }
.tip-item::before { position: absolute; left: 0; }
.tip-bad .tip-item::before { content: "✗"; color: var(--red); }
.tip-good .tip-item::before { content: "✓"; color: var(--green); }

/* Exercise */
.exercise {
  background: var(--accent-dim); border: 1px solid var(--accent);
  border-radius: 10px; padding: 16px; margin-bottom: 12px;
}
.exercise-num { font-size: 11px; color: var(--accent2); font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 6px; }
.exercise-text { font-size: 14px; font-weight: 500; margin-bottom: 8px; }
.exercise-desc { font-size: 13px; color: var(--text2); }

/* Roadmap */
.roadmap-step {
  display: flex; align-items: flex-start; gap: 16px; margin-bottom: 0;
}
.roadmap-line { display: flex; flex-direction: column; align-items: center; }
.roadmap-dot {
  width: 12px; height: 12px; border-radius: 50%;
  border: 2px solid var(--green); background: var(--green);
  flex-shrink: 0; margin-top: 4px;
}
.roadmap-dot.dim { background: var(--bg4); border-color: var(--border); }
.roadmap-connector { width: 2px; flex: 1; min-height: 24px; background: var(--border); }
.roadmap-step:last-child .roadmap-connector { display: none; }
.roadmap-content { padding-bottom: 20px; flex: 1; }
.roadmap-title { font-size: 14px; font-weight: 600; margin-bottom: 2px; }
.roadmap-desc { font-size: 12px; color: var(--text3); }

/* Chip badges */
.chip {
  display: inline-flex; align-items: center;
  padding: 3px 10px; border-radius: 100px;
  font-size: 11px; font-weight: 600; margin: 3px 3px 3px 0;
}
.chip-green { background: var(--green-dim); color: var(--green); border: 1px solid rgba(34,197,94,0.3); }
.chip-purple { background: var(--accent-dim); color: var(--accent2); border: 1px solid rgba(99,102,241,0.3); }
.chip-yellow { background: var(--yellow-dim); color: var(--yellow); border: 1px solid rgba(245,158,11,0.3); }
.chip-red { background: var(--red-dim); color: var(--red); border: 1px solid rgba(239,68,68,0.3); }

/* Companies */
.company-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; margin: 16px 0; }
.company-card {
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: 10px; padding: 14px; text-align: center;
}
.company-logo { font-size: 26px; margin-bottom: 6px; }
.company-name { font-weight: 700; font-size: 14px; margin-bottom: 4px; }
.company-why { font-size: 11px; color: var(--text3); line-height: 1.5; }

/* Next day banner */
.next-day {
  background: linear-gradient(135deg, var(--accent-dim), var(--bg3));
  border: 1px solid var(--accent);
  border-radius: 14px;
  padding: 20px 24px;
  margin-top: 32px;
  display: flex; align-items: center; justify-content: space-between; gap: 16px;
}
.next-day-text h3 { font-size: 16px; font-weight: 700; margin-bottom: 4px; }
.next-day-text p { font-size: 13px; color: var(--text2); margin: 0; }
.next-day-topics { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }

/* Notes */
.notes-area {
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: 10px; padding: 16px; margin: 14px 0;
}
.notes-area textarea {
  width: 100%; background: none; border: none; outline: none;
  color: var(--text2); font-family: 'Inter', sans-serif; font-size: 13px;
  line-height: 1.7; resize: vertical; min-height: 100px;
}

/* Sticky note */
.sticky-note {
  background: #fef3c7; color: #92400e;
  border-radius: 4px 4px 4px 0;
  padding: 12px 14px; margin: 14px 0;
  font-size: 13px; position: relative;
  box-shadow: 2px 2px 6px rgba(0,0,0,0.15);
}
:root[data-theme="dark"] .sticky-note { background: rgba(251,191,36,0.12); color: #fbbf24; }

/* Divider */
.divider { height: 1px; background: var(--border); margin: 20px 0; }

/* Flow step */
.flow-steps { counter-reset: flow; }
.flow-step {
