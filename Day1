node -v
<span class="cm"># Expected output: v20.x.x (or similar LTS version)</span>

<span class="cm"># Check NPM version</span>
npm -v
<span class="cm"># Expected output: 10.x.x</span></pre>
        </div>

        <div class="callout warning">
          <div class="callout-icon">⚠️</div>
          <div class="callout-text"><strong>Always use LTS (Long Term Support)</strong> version, not the "Current" version. LTS is stable and recommended for production projects. LTS versions are even numbers: 18, 20, 22.</div>
        </div>

        <h3>Common Installation Errors &amp; Fixes</h3>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Error</th><th>Cause</th><th>Fix</th></tr></thead>
            <tbody>
              <tr><td>'node' is not recognized</td><td>PATH not set</td><td>Restart terminal, or re-install Node</td></tr>
              <tr><td>EACCES permissions error</td><td>Linux/Mac user rights</td><td>Use NVM or fix npm prefix</td></tr>
              <tr><td>Version too old</td><td>Old Node installed</td><td>Use NVM to manage versions</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- S7: FIRST PROGRAM -->
    <div class="section open" id="s7">
      <div class="section-head" onclick="toggle('s7')">
        <div class="section-num">07</div>
        <div class="section-title">Your First Node.js Program</div>
        <div class="section-chevron">▼</div>
      </div>
      <div class="section-body">
        <h3>Hello, Node.js!</h3>
        <div class="code-block">
          <div class="code-header"><span class="code-lang">hello.js</span><span class="code-copy" onclick="copyCode(this)">Copy</span></div>
          <pre><span class="cm">// hello.js — Your first Node.js program</span>
<span class="fn">console</span>.<span class="fn">log</span>(<span class="str">"Hello, Node.js! 🚀"</span>);
<span class="fn">console</span>.<span class="fn">log</span>(<span class="str">"I am running on the server!"</span>);
<span class="fn">console</span>.<span class="fn">log</span>(<span class="str">"Node version:"</span>, <span class="var">process</span>.<span class="var">version</span>);
<span class="fn">console</span>.<span class="fn">log</span>(<span class="str">"Platform:"</span>, <span class="var">process</span>.<span class="var">platform</span>);
<span class="fn">console</span>.<span class="fn">log</span>(<span class="str">"Current directory:"</span>, <span class="var">__dirname</span>);</pre>
        </div>

        <div class="code-block">
          <div class="code-header"><span class="code-lang">Terminal — Run it</span><span class="code-copy" onclick="copyCode(this)">Copy</span></div>
          <pre>node hello.js

<span class="cm"># Output:</span>
Hello, Node.js! 🚀
I am running on the server!
Node version: v20.10.0
Platform: linux
Current directory: /home/user/projects</pre>
        </div>

        <h3>What Happens Internally</h3>
        <div class="diagram">
          <div class="node">hello.js (your file)</div>
          <div class="arrow">↓ node hello.js (terminal command)</div>
          <div class="node yellow">Node.js reads the file</div>
          <div class="arrow">↓ passes code to V8</div>
          <div class="node green">V8 Engine compiles &amp; executes</div>
          <div class="arrow">↓</div>
          <div class="node purple">Output appears in your terminal ✅</div>
        </div>

        <div class="callout success">
          <div class="callout-icon">🎉</div>
